{
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": 1
	},
	"permissions": {
		"allow": ["Bash"]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-deps.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "FILE=$(jq -r '.tool_input.file_path' 2>/dev/null) && case \"$FILE\" in *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs|*.md) oxfmt \"$FILE\" 2>/dev/null ;; esac; exit 0"
					}
				]
			}
		]
	}
}
