{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": [
		"eslint",
		"typescript",
		"unicorn",
		"oxc",
		"import",
		"promise",
		"node",
		"react",
		"jsx-a11y"
	],
	"env": {
		"es2024": true,
		"node": true
	},
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "error",
		"perf": "error",
		"style": "off",
		"restriction": "off"
	},
	"rules": {
		"eslint/no-console": "off",
		"eslint/no-unused-vars": "error",
		"eslint/max-lines": ["error", { "max": 300, "skipBlankLines": true, "skipComments": true }],
		"eslint/max-lines-per-function": [
			"error",
			{ "max": 80, "skipBlankLines": true, "skipComments": true }
		],
		"eslint/max-params": ["error", { "max": 4 }],
		"typescript/no-explicit-any": "error",
		"typescript/consistent-type-imports": "error",
		"typescript/no-non-null-assertion": "error",
		"typescript/no-import-type-side-effects": "error",
		"typescript/no-require-imports": "off",
		"unicorn/no-null": "off",
		"unicorn/prefer-top-level-await": "off",
		"unicorn/no-process-exit": "off",
		"unicorn/filename-case": "off",
		"unicorn/prevent-abbreviations": "off",
		"unicorn/no-array-for-each": "off",
		"node/no-process-env": "off",
		"import/no-cycle": "error",
		"import/no-self-import": "error",
		"import/no-duplicates": "error",
		"import/no-mutable-exports": "error",
		"import/first": "error",
		"import/no-anonymous-default-export": "error",
		"promise/no-return-wrap": "error",
		"promise/param-names": "error",
		"promise/catch-or-return": "error",
		"react/react-in-jsx-scope": "off",

		"typescript/no-unsafe-call": "off",
		"typescript/no-unsafe-member-access": "off",
		"typescript/no-unsafe-type-assertion": "off",
		"typescript/no-unsafe-assignment": "off",
		"typescript/no-unsafe-argument": "error",
		"typescript/no-unsafe-return": "error",
		"typescript/strict-boolean-expressions": "off",
		"typescript/no-confusing-void-expression": "off",
		"typescript/unbound-method": "off",
		"typescript/await-thenable": "error"
	},
	"overrides": [
		{
			"files": ["scripts/**/*.ts"],
			"rules": {
				"eslint/max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
				"eslint/max-lines-per-function": [
					"warn",
					{ "max": 200, "skipBlankLines": true, "skipComments": true }
				]
			}
		},
		{
			"files": ["**/bootstrap.ts"],
			"rules": {
				"import/max-dependencies": "off",
				"eslint/max-lines": ["warn", { "max": 600, "skipBlankLines": true, "skipComments": true }],
				"eslint/max-lines-per-function": [
					"warn",
					{ "max": 200, "skipBlankLines": true, "skipComments": true }
				]
			}
		},
		{
			"files": ["**/*.test.ts", "**/*.spec.ts", "**/test-helpers.ts"],
			"rules": {
				"eslint/max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
				"eslint/max-lines-per-function": [
					"warn",
					{ "max": 300, "skipBlankLines": true, "skipComments": true }
				],
				"eslint/max-params": "off",
				"import/max-dependencies": "off"
			}
		},
		{
			"files": ["**/mcp/**/tools/*.ts", "**/mcp/**/core-server.ts", "**/minecraft/**/mcp-tools.ts"],
			"rules": {
				"eslint/max-lines-per-function": [
					"warn",
					{ "max": 200, "skipBlankLines": true, "skipComments": true }
				],
				"import/max-dependencies": "off"
			}
		},
		{
			"files": ["packages/shared/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/",
								"message": "shared は他の workspace パッケージに依存できません"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/ollama/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/",
								"message": "ollama は他の workspace パッケージに依存できません"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/opencode/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/)",
								"message": "opencode は shared のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/observability/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/)",
								"message": "observability は shared のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/store/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/)",
								"message": "store は shared のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/application/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/)",
								"message": "application は shared のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/agent/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/|opencode/|store/)",
								"message": "agent は shared, opencode, store のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/memory/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/|ollama(?:/|$))",
								"message": "memory は shared, ollama のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/infrastructure/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/|application/|store/)",
								"message": "infrastructure は shared, application, store のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/scheduling/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/|application/|observability/)",
								"message": "scheduling は shared, application, observability のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/mcp/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/|infrastructure/|memory/|memory$|ollama(?:/|$)|store/)",
								"message": "mcp は shared, infrastructure, memory, ollama, store のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["packages/minecraft/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "@vicissitude/(?!shared/|store/)",
								"message": "minecraft は shared, store のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["apps/discord/src/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": "off"
			}
		},
		{
			"files": ["apps/web/src/**/*.{ts,tsx}"],
			"rules": {
				"eslint/no-restricted-imports": "off"
			}
		}
	],
	"ignorePatterns": ["node_modules", "data", ".direnv", "context"]
}
