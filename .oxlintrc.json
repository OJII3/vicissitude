{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["eslint", "typescript", "unicorn", "oxc", "import", "promise", "node"],
	"env": {
		"es2024": true,
		"node": true
	},
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "error",
		"perf": "error",
		"style": "off",
		"restriction": "off"
	},
	"rules": {
		"eslint/no-console": "off",
		"eslint/no-unused-vars": "error",
		"typescript/no-explicit-any": "error",
		"typescript/consistent-type-imports": "error",
		"typescript/no-non-null-assertion": "error",
		"typescript/no-import-type-side-effects": "error",
		"typescript/no-require-imports": "off",
		"unicorn/no-null": "off",
		"unicorn/prefer-top-level-await": "off",
		"unicorn/no-process-exit": "off",
		"unicorn/filename-case": "off",
		"unicorn/prevent-abbreviations": "off",
		"unicorn/no-array-for-each": "off",
		"node/no-process-env": "off",
		"import/no-cycle": "error",
		"import/no-self-import": "error",
		"import/no-duplicates": "error",
		"import/no-mutable-exports": "error",
		"import/first": "error",
		"import/no-anonymous-default-export": "error",
		"promise/no-return-wrap": "error",
		"promise/param-names": "error",
		"promise/catch-or-return": "error"
	},
	"overrides": [
		{
			"files": ["scripts/**/*.ts"],
			"rules": {
				"eslint/max-lines": "off",
				"eslint/max-lines-per-function": "off"
			}
		},
		{
			"files": ["**/bootstrap.ts"],
			"rules": {
				"import/max-dependencies": "off",
				"eslint/max-lines-per-function": "off"
			}
		},
		{
			"files": ["**/*.test.ts", "**/*.spec.ts", "**/test-helpers.ts"],
			"rules": {
				"eslint/max-lines-per-function": "off",
				"eslint/max-lines": "off",
				"import/max-dependencies": "off"
			}
		},
		{
			"files": ["**/mcp/**/tools/*.ts", "**/mcp/**/core-server.ts", "**/minecraft/**/mcp-tools.ts"],
			"rules": {
				"eslint/max-lines-per-function": "off",
				"import/max-dependencies": "off"
			}
		},
		{
			"files": ["**/core/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|gateway|mcp|store|observability|fenghuang|ollama|opencode)/",
								"message": "core/ は他の内部モジュールに依存できません"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/opencode/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|gateway|mcp|store|observability|fenghuang|ollama)/",
								"message": "opencode/ は core/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/observability/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|gateway|mcp|store|fenghuang|ollama|opencode)/",
								"message": "observability/ は core/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/ollama/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|gateway|mcp|store|observability|fenghuang|opencode)/",
								"message": "ollama/ は core/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/store/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|gateway|mcp|observability|fenghuang|ollama|opencode)/",
								"message": "store/ は core/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/agent/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(gateway|mcp|observability|fenghuang|ollama)/",
								"message": "agent/ は core/, store/, opencode/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/fenghuang/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|gateway|mcp|store|observability)/",
								"message": "fenghuang/ は core/, ollama/, opencode/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/scheduling/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|gateway|mcp|store|fenghuang|ollama|opencode)/",
								"message": "scheduling/ は core/, observability/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/gateway/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(mcp|fenghuang|ollama|opencode)/",
								"message": "gateway/ は core/, agent/, store/, observability/ のみに依存できます"
							}
						]
					}
				]
			}
		},
		{
			"files": ["**/mcp/**/*.ts"],
			"rules": {
				"eslint/no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"regex": "/(agent|observability)/",
								"message": "mcp/ は agent/, observability/ に依存できません"
							}
						]
					}
				]
			}
		}
	],
	"ignorePatterns": ["node_modules", "data", ".direnv", "context"]
}
