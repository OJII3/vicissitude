{
	"name": "vicissitude",
	"private": true,
	"type": "module",
	"module": "src/index.ts",
	"scripts": {
		"start": "bun run src/index.ts",
		"dev": "bun --watch run src/index.ts",
		"check": "tsgo --noEmit",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"test": "bun test",
		"validate": "bun run fmt:check && bun run lint && bun run check"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@opencode-ai/sdk": "^1.2.15",
		"discord.js": "^14.25.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@typescript/native-preview": "^7.0.0-dev.20260228.1",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
