FROM ghcr.io/jdx/mise

# mise で bun, node, python をインストール（python 3.11 は distutils を標準搭載）
RUN mise use -g bun@1 node@24 python@3.11

# システム依存パッケージ
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    podman \
    # canvas v3 (N-API) native build deps
    build-essential libcairo2-dev libpango1.0-dev libjpeg-dev libgif-dev librsvg2-dev \
    # headless-gl (Mesa + Xvfb + ANGLE build) deps
    xvfb xauth libgl1-mesa-dri libgl1-mesa-dev libglapi-mesa libosmesa6 libxi-dev \
    && apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN bun install -g opencode-ai@1.4.3 && \
    cp /root/.bun/install/global/node_modules/opencode-ai/bin/.opencode /usr/local/bin/opencode && \
    chmod 755 /usr/local/bin/opencode && \
    rm -rf /root/.bun && \
    opencode --version

WORKDIR /app

# userns keep-id で uid 1000 として実行されるため書き込み可能にする
RUN mkdir -p data/context node_modules dist \
    .local/share/opencode/bin .local/state/mise .config && \
    chown -R 1000:1000 /app

ENV CONTAINER_HOST=unix:///run/podman/podman.sock

ENTRYPOINT []
